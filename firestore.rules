rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: farmers
    // Fields: name, county, town, gps_lat, gps_lng, crops, farm_size_acres, language_preference, created_at, last_active
    //
    // Collection: field_data (subcollection of farmers)
    // Fields: alu_field_boundary, alu_acreage, alu_water_bodies, amed_detected_crop, amed_crop_stage, amed_sowing_date, amed_harvest_estimate, amed_ndvi, amed_last_updated, historical_seasons
    //
    // Collection: conversations (subcollection of farmers)
    // Fields: messages, session_date, topics_covered, photos_analyzed
    //
    // Collection: disease_reports
    // Fields: farmer_id, county, location_lat, location_lng, disease_identified, confidence, photo_url, timestamp, verified
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "obilasam3@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidFarmer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.county is string &&
             data.town is string &&
             data.gps_lat is number &&
             data.gps_lng is number;
    }

    function isValidDiseaseReport(data) {
      return data.farmer_id is string &&
             data.disease_identified is string &&
             data.confidence in ['High', 'Medium', 'Low'] &&
             data.photo_url is string;
    }

    // Rules
    match /farmers/{farmerId} {
      allow read: if isOwner(farmerId) || isAdmin();
      allow create: if isOwner(farmerId) && isValidFarmer(request.resource.data);
      allow update: if isOwner(farmerId) && isValidFarmer(request.resource.data);

      match /field_data/{docId} {
        allow read: if isOwner(farmerId) || isAdmin();
        allow write: if isAdmin(); // Only admins/system can update satellite data
      }

      match /conversations/{sessionId} {
        allow read: if isOwner(farmerId) || isAdmin();
        allow create: if isOwner(farmerId);
        allow update: if isOwner(farmerId);
      }
    }

    match /disease_reports/{reportId} {
      allow read: if isAuthenticated(); // All farmers can see the heatmap
      allow create: if isAuthenticated() && isValidDiseaseReport(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
