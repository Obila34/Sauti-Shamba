{
  "entities": {
    "Farmer": {
      "title": "Farmer",
      "description": "Profile information for a farmer.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Farmer's name" },
        "county": { "type": "string", "description": "County of residence" },
        "town": { "type": "string", "description": "Town of residence" },
        "gps_lat": { "type": "number", "description": "Latitude coordinate" },
        "gps_lng": { "type": "number", "description": "Longitude coordinate" },
        "crops": { "type": "array", "items": { "type": "string" }, "description": "Crops grown by the farmer" },
        "farm_size_acres": { "type": "number", "description": "Size of the farm in acres" },
        "language_preference": { "type": "string", "enum": ["en", "sw", "sheng"], "description": "Preferred language" },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of creation" },
        "last_active": { "type": "string", "format": "date-time", "description": "Timestamp of last activity" }
      },
      "required": ["name", "county", "town", "gps_lat", "gps_lng", "created_at"]
    },
    "FieldData": {
      "title": "FieldData",
      "description": "Satellite and environmental data for a farmer's field.",
      "type": "object",
      "properties": {
        "alu_field_boundary": { "type": "array", "items": { "type": "object" }, "description": "GPS polygon coordinates" },
        "alu_acreage": { "type": "number", "description": "Calculated farm size" },
        "alu_water_bodies": { "type": "array", "items": { "type": "object" }, "description": "Nearby water sources" },
        "amed_detected_crop": { "type": "string", "description": "Satellite-detected crop" },
        "amed_crop_stage": { "type": "string", "description": "Current growth stage" },
        "amed_sowing_date": { "type": "string", "format": "date", "description": "Detected sowing date" },
        "amed_harvest_estimate": { "type": "string", "format": "date", "description": "Predicted harvest window" },
        "amed_ndvi": { "type": "number", "description": "Vegetation index (0-1)" },
        "amed_last_updated": { "type": "string", "format": "date-time", "description": "Last update from satellite" },
        "historical_seasons": { "type": "array", "items": { "type": "object" }, "description": "Past season records" }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat session between a farmer and Zao.",
      "type": "object",
      "properties": {
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "session_date": { "type": "string", "format": "date-time" },
        "topics_covered": { "type": "array", "items": { "type": "string" } },
        "photos_analyzed": { "type": "array", "items": { "type": "string" } }
      }
    },
    "DiseaseReport": {
      "title": "DiseaseReport",
      "description": "A report of a crop disease diagnosis.",
      "type": "object",
      "properties": {
        "farmer_id": { "type": "string" },
        "county": { "type": "string" },
        "location_lat": { "type": "number" },
        "location_lng": { "type": "number" },
        "disease_identified": { "type": "string" },
        "confidence": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "photo_url": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "verified": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/farmers/{farmerId}": { "schema": "Farmer", "description": "Farmer profiles." },
    "/farmers/{farmerId}/field_data/current": { "schema": "FieldData", "description": "Current satellite data for the farmer." },
    "/farmers/{farmerId}/conversations/{sessionId}": { "schema": "Conversation", "description": "Chat history." },
    "/disease_reports/{reportId}": { "schema": "DiseaseReport", "description": "Global disease reports for heatmap." }
  }
}
